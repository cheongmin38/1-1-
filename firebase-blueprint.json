{
  "entities": {
    "Notice": {
      "title": "Class Notice",
      "description": "Notices posted by teachers or authorized students",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "The notice text" },
        "authorName": { "type": "string", "description": "Author's name" },
        "createdAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["general", "urgent", "assessment"] },
        "attachments": { 
          "type": "array", 
          "items": { "type": "string", "description": "Base64 encoded file data or URLs" } 
        }
      },
      "required": ["content", "authorName", "createdAt"]
    },
    "Event": {
      "title": "Class Event",
      "description": "Calendar events for the class",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["exam", "activity", "holiday", "other"] }
      },
      "required": ["title", "date", "type"]
    },
    "AppConfig": {
      "title": "App Configuration",
      "description": "Global settings for the application",
      "type": "object",
      "properties": {
        "authorizedStudentNumber": { "type": "string", "description": "Student number allowed to post assessment notices" }
      }
    },
    "StudentProfile": {
      "title": "Student Profile",
      "description": "Profile information for each student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "name": { "type": "string" },
        "bio": { "type": "string" },
        "totalPlansGenerated": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "name"]
    },
    "StudyPlan": {
      "title": "Study Plan",
      "description": "AI generated study plans for students",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subject": { "type": "string" },
        "goal": { "type": "string" },
        "level": { "type": "string" },
        "plan": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "subject", "goal", "plan", "createdAt"]
    },
    "FreeBoardPost": {
      "title": "Free Board Post",
      "description": "Post in the class free board",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "isAnonymous": { "type": "boolean" },
        "category": { "type": "string", "enum": ["funny", "improvement", "discomfort", "chat"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "likes": { "type": "number" },
        "likedBy": { "type": "array", "items": { "type": "string" }, "description": "Array of student IDs who liked the post" }
      },
      "required": ["content", "authorId", "authorName", "isAnonymous", "category", "createdAt"]
    },
    "Comment": {
      "title": "Post Comment",
      "description": "Comment on a free board post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "isAnonymous": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "authorName", "content", "isAnonymous", "createdAt"]
    },
    "Notification": {
      "title": "User Notification",
      "description": "Notifications for users when someone interacts with their content",
      "type": "object",
      "properties": {
        "targetUserId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string", "enum": ["comment", "like", "notice", "reply"] },
        "link": { "type": "string", "description": "Optional deep link or tab reference" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["targetUserId", "title", "body", "type", "isRead", "createdAt"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A conversation with the AI Study Bot",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "lastMessage", "updatedAt"]
    },
    "SavedPlan": {
      "title": "Saved Plan",
      "description": "A study plan generated by AI and saved by the user",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "title", "content", "createdAt"]
    }
  },
  "firestore": {
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "Collection of all class notices"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Collection of calendar events"
    },
    "/config/permissions": {
      "schema": "AppConfig",
      "description": "Central permissions configuration"
    },
    "/profiles/{studentId}": {
      "schema": "StudentProfile",
      "description": "Student profile data"
    },
    "/study_plans/{planId}": {
      "schema": "StudyPlan",
      "description": "Saved AI study plans"
    },
    "/free_board/{postId}": {
      "schema": "FreeBoardPost",
      "description": "Collection of free board posts"
    },
    "/chats/{chatId}": {
      "schema": "ChatSession",
      "description": "AI Study Chat sessions"
    },
    "/saved_plans/{planId}": {
      "schema": "SavedPlan",
      "description": "User's saved AI study plans"
    },
    "/free_board/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on free board posts"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
