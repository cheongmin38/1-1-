rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return true; // Simple app using local storage for identification
    }

    function isValidNotice(data) {
      return data.content is string && data.content.size() <= 1048576 // Expanded for base64 images
             && data.authorName is string && data.authorName.size() <= 100
             && data.createdAt is timestamp;
    }

    function isAuthorizedStudent(studentNum) {
      return get(/databases/$(database)/documents/config/permissions).data.authorizedStudentNumber == studentNum;
    }

    function isValidFreeBoardPost(data) {
      return data.content is string && data.content.size() <= 5000
             && data.authorName is string && data.authorName.size() <= 100
             && data.authorId is string && data.authorId.size() <= 100
             && data.isAnonymous is bool
             && data.category in ['funny', 'improvement', 'discomfort', 'chat']
             && data.createdAt is timestamp;
    }

    match /free_board/{postId} {
      allow read: if true;
      allow create: if isValidFreeBoardPost(request.resource.data);
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']);
      allow delete: if true; // Simple app, allowing delete
    }

    function isValidChatSession(data) {
      return data.studentId is string && data.studentId.size() <= 100
             && data.lastMessage is string && data.lastMessage.size() <= 5000
             && data.updatedAt is timestamp;
    }

    match /chats/{chatId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.studentId == request.auth.uid);
    }

    // Since we don't have real Firebase Auth (simulated LoginGate), we rely on studentId
    // In a real app, we'd use request.auth.uid
    // For this context, we will allow based on the provided studentId in data
    
    match /chats/{chatId} {
      allow read, write: if true; // Simplified for this school app demo
    }

    function isValidSavedPlan(data) {
      return data.studentId is string && data.studentId.size() <= 100
             && data.title is string && data.title.size() <= 200
             && data.content is string && data.content.size() <= 10000
             && data.createdAt is timestamp;
    }

    match /saved_plans/{planId} {
      allow read: if true;
      allow create: if isValidSavedPlan(request.resource.data);
      allow delete: if true;
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow create: if isValidNotice(request.resource.data); 
      allow delete: if true;
      allow update: if false; 
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if true; // Simple demo, allow management
    }

    match /config/permissions {
      allow read: if true;
      allow write: if true; // Teachers will update this
    }

    match /profiles/{studentId} {
      allow read, write: if true;
    }

    match /study_plans/{planId} {
       allow read: if true;
       allow create: if true;
       allow delete: if true;
    }
  }
}
