rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global functions
    function isSignedIn() {
      return true; // Simplified for this demo structure
    }

    // Notices
    match /notices/{noticeId} {
      allow read: if true;
      allow create: if request.resource.data.content is string 
                    && request.resource.data.authorName is string;
      allow delete: if true;
      allow update: if true;
    }

    // Free Board
    match /free_board/{postId} {
      allow read: if true;
      allow create: if request.resource.data.content is string 
                    && request.resource.data.authorId is string;
      allow update: if true; // Allow likes and edits
      allow delete: if true;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.resource.data.content is string;
        allow delete: if true;
      }
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // AI Chats
    match /chats/{chatId} {
      allow read, write: if true;
    }

    // Saved Plans (AI Study Bot)
    match /saved_plans/{planId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
    }

    // Profiles
    match /profiles/{studentId} {
      allow read, write: if true;
    }

    // Study Plans (Manual)
    match /study_plans/{planId} {
       allow read, write: if true;
    }

    // Events (Calendar)
    match /events/{eventId} {
      allow read, write: if true;
    }

    // Config
    match /config/{docId} {
      allow read, write: if true;
    }

    // Catch-all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
