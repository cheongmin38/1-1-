rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return true; // Simple app using local storage for identification
    }

    function isValidNotice(data) {
      return data.content is string && data.content.size() <= 1048576 // Expanded for base64 images
             && data.authorName is string && data.authorName.size() <= 100
             && data.createdAt is timestamp;
    }

    function isAuthorizedStudent(studentNum) {
      return get(/databases/$(database)/documents/config/permissions).data.authorizedStudentNumber == studentNum;
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow create: if isValidNotice(request.resource.data); 
      allow delete: if true;
      allow update: if false; 
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if true; // Simple demo, allow management
    }

    match /config/permissions {
      allow read: if true;
      allow write: if true; // Teachers will update this
    }
  }
}
